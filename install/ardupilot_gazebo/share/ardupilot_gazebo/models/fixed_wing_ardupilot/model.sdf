<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="fixed_wing">
    <!-- Main fuselage body -->
    <link name="fuselage">
      <pose>0 0 0.12 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>2.0</mass>
        <inertia>
          <ixx>0.120</ixx>
          <ixy>0</ixy>
          <iyy>0.450</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.510</izz>
        </inertia>
      </inertial>
      <visual name="fuselage_visual">
        <geometry>
          <mesh>
            <uri>model://fixed_wing_ardupilot/meshes/fuselage.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.8 0.2 0.2 1.0</ambient>
          <diffuse>0.8 0.2 0.2 1.0</diffuse>
        </material>
      </visual>
      <collision name="fuselage_collision">
        <geometry>
          <mesh>
            <uri>model://fixed_wing_ardupilot/meshes/fuselage.stl</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <!-- Main wing -->
    <link name="wing">
      <pose>0 0 0.18 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.8</mass>
        <inertia>
          <ixx>0.035</ixx>
          <ixy>0</ixy>
          <iyy>0.010</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.045</izz>
        </inertia>
      </inertial>
      <visual name="wing_visual">
        <geometry>
          <mesh>
            <uri>model://fixed_wing_ardupilot/meshes/wings.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.6 0.2 1.0</ambient>
          <diffuse>0.2 0.6 0.2 1.0</diffuse>
        </material>
      </visual>
      <collision name="wing_collision">
        <geometry>
          <mesh>
            <uri>model://fixed_wing_ardupilot/meshes/wings.stl</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <!-- Horizontal and vertical stabilizers -->
    <link name="h_stab">
      <pose>-0.48 0 0.18 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.25</mass>
        <inertia>
          <ixx>0.005</ixx>
          <ixy>0</ixy>
          <iyy>0.002</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.007</izz>
        </inertia>
      </inertial>
      <visual name="tail_visual">
        <geometry>
          <mesh>
            <uri>model://fixed_wing_ardupilot/meshes/tail.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.2 0.2 0.8 1.0</ambient>
          <diffuse>0.2 0.2 0.8 1.0</diffuse>
        </material>
      </visual>
      <collision name="tail_collision">
        <geometry>
          <mesh>
            <uri>model://fixed_wing_ardupilot/meshes/tail.stl</uri>
          </mesh>
        </geometry>
      </collision>
    </link>

    <!-- Elevator surface -->
    <link name="elevator">
      <pose>-0.48 0 0.12 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.05</mass>
        <inertia>
          <ixx>0.001</ixx>
          <ixy>0</ixy>
          <iyy>0.0005</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.0015</izz>
        </inertia>
      </inertial>
      <visual name="elevator_visual">
        <geometry>
          <box>
            <size>0.4 0.05 0.03</size>
          </box>
        </geometry>
        <material>
          <ambient>0.8 0.8 0.2 1.0</ambient>
          <diffuse>0.8 0.8 0.2 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Rudder surface -->
    <link name="rudder">
      <pose>-0.48 0.025 0.24 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.04</mass>
        <inertia>
          <ixx>0.0008</ixx>
          <ixy>0</ixy>
          <iyy>0.0003</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.0011</izz>
        </inertia>
      </inertial>
      <visual name="rudder_visual">
        <geometry>
          <box>
            <size>0.05 0.08 0.08</size>
          </box>
        </geometry>
        <material>
          <ambient>0.8 0.2 0.8 1.0</ambient>
          <diffuse>0.8 0.2 0.8 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Left aileron -->
    <link name="aileron_left">
      <pose>0.6 0.65 0.18 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.08</mass>
        <inertia>
          <ixx>0.002</ixx>
          <ixy>0</ixy>
          <iyy>0.0005</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.0025</izz>
        </inertia>
      </inertial>
      <visual name="aileron_left_visual">
        <geometry>
          <box>
            <size>0.3 0.04 0.03</size>
          </box>
        </geometry>
        <material>
          <ambient>0.8 0.8 0.2 1.0</ambient>
          <diffuse>0.8 0.8 0.2 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Right aileron -->
    <link name="aileron_right">
      <pose>0.6 -0.65 0.18 0 0 0</pose>
      <inertial>
        <pose>0 0 0 0 0 0</pose>
        <mass>0.08</mass>
        <inertia>
          <ixx>0.002</ixx>
          <ixy>0</ixy>
          <iyy>0.0005</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.0025</izz>
        </inertia>
      </inertial>
      <visual name="aileron_right_visual">
        <geometry>
          <box>
            <size>0.3 0.04 0.03</size>
          </box>
        </geometry>
        <material>
          <ambient>0.8 0.8 0.2 1.0</ambient>
          <diffuse>0.8 0.8 0.2 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Propeller -->
    <link name="propeller">
      <pose degrees="true">0.6 0 0.12 0 90 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.0008</ixx>
          <ixy>0</ixy>
          <iyy>0.0008</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.000015</izz>
        </inertia>
      </inertial>
      <visual name="propeller_visual">
        <geometry>
          <mesh>
            <uri>model://fixed_wing_ardupilot/meshes/propeller.stl</uri>
          </mesh>
        </geometry>
        <material>
          <ambient>0.3 0.3 0.3 1.0</ambient>
          <diffuse>0.3 0.3 0.3 1.0</diffuse>
        </material>
      </visual>
    </link>

    <!-- Nose wheel -->
    <link name="nose_wheel">
      <pose>0.4 0 -0.13 0 0 0</pose>
      <inertial>
        <mass>0.1</mass>
        <inertia>
          <ixx>0.002</ixx>
          <ixy>0</ixy>
          <iyy>0.002</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.004</izz>
        </inertia>
      </inertial>
      <collision name="nose_wheel_collision">
        <geometry>
          <sphere>
            <radius>0.05</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>0.8</mu>
              <mu2>0.8</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- Main landing gear left wheel -->
    <link name="main_wheel_left">
      <pose>-0.2 0.35 -0.10 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.004</ixx>
          <ixy>0</ixy>
          <iyy>0.004</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.008</izz>
        </inertia>
      </inertial>
      <collision name="main_wheel_left_collision">
        <geometry>
          <sphere>
            <radius>0.08</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- Main landing gear right wheel -->
    <link name="main_wheel_right">
      <pose>-0.2 -0.35 -0.10 0 0 0</pose>
      <inertial>
        <mass>0.15</mass>
        <inertia>
          <ixx>0.004</ixx>
          <ixy>0</ixy>
          <iyy>0.004</iyy>
          <ixz>0</ixz>
          <iyz>0</iyz>
          <izz>0.008</izz>
        </inertia>
      </inertial>
      <collision name="main_wheel_right_collision">
        <geometry>
          <sphere>
            <radius>0.08</radius>
          </sphere>
        </geometry>
        <surface>
          <friction>
            <ode>
              <mu>1.0</mu>
              <mu2>1.0</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
    </link>

    <!-- Joints -->
    <joint name="wing_joint" type="fixed">
      <parent>fuselage</parent>
      <child>wing</child>
    </joint>

    <joint name="h_stab_joint" type="fixed">
      <parent>fuselage</parent>
      <child>h_stab</child>
    </joint>

    <joint name="elevator_joint" type="revolute">
      <parent>h_stab</parent>
      <child>elevator</child>
      <pose>0 0 0.025 0 0 0</pose>
      <axis>
        <xyz>1 0 0</xyz>
        <limit>
          <lower>-0.349</lower>
          <upper>0.349</upper>
          <effort>10</effort>
          <velocity>3.0</velocity>
        </limit>
        <dynamics>
          <damping>0.5</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="rudder_joint" type="revolute">
      <parent>h_stab</parent>
      <child>rudder</child>
      <axis>
        <xyz>0 0 1</xyz>
        <limit>
          <lower>-0.349</lower>
          <upper>0.349</upper>
          <effort>10</effort>
          <velocity>3.0</velocity>
        </limit>
        <dynamics>
          <damping>0.5</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="aileron_left_joint" type="revolute">
      <parent>wing</parent>
      <child>aileron_left</child>
      <axis>
        <xyz>1 0.174 0</xyz>
        <limit>
          <lower>-0.349</lower>
          <upper>0.349</upper>
          <effort>5</effort>
          <velocity>3.0</velocity>
        </limit>
        <dynamics>
          <damping>0.3</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="aileron_right_joint" type="revolute">
      <parent>wing</parent>
      <child>aileron_right</child>
      <axis>
        <xyz>1 -0.174 0</xyz>
        <limit>
          <lower>-0.349</lower>
          <upper>0.349</upper>
          <effort>5</effort>
          <velocity>3.0</velocity>
        </limit>
        <dynamics>
          <damping>0.3</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="propeller_joint" type="revolute">
      <parent>fuselage</parent>
      <child>propeller</child>
      <axis>
        <xyz>0 1 0</xyz>
        <dynamics>
          <damping>0.004</damping>
        </dynamics>
      </axis>
    </joint>

    <joint name="nose_wheel_joint" type="fixed">
      <parent>fuselage</parent>
      <child>nose_wheel</child>
    </joint>

    <joint name="main_wheel_left_joint" type="fixed">
      <parent>fuselage</parent>
      <child>main_wheel_left</child>
    </joint>

    <joint name="main_wheel_right_joint" type="fixed">
      <parent>fuselage</parent>
      <child>main_wheel_right</child>
    </joint>

  </model>
</sdf>

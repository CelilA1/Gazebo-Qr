<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="plane_with_ardupilot">
    <pose>0 0 0.495 0 0 0</pose>

    <!-- ===================== CESSNA C-172 BODY ===================== -->
    <link name="body">
      <inertial>
        <mass>680.389</mass>
        <inertia>
          <ixx>1285.315427874</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>1824.930976707</iyy><iyz>0</iyz>
          <izz>2666.893931043</izz>
        </inertia>
        <pose>-0.0414 0 0.9271 0 0 0</pose>
      </inertial>
      <collision name="collision">
        <geometry>
          <mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/body.dae</uri></mesh>
        </geometry>
      </collision>
      <visual name="visual">
        <geometry>
          <mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/body.dae</uri></mesh>
        </geometry>
      </visual>

      <!-- IMU -->
      <sensor name="imu_sensor" type="imu">
        <always_on>1</always_on>
        <update_rate>200</update_rate>
      </sensor>
      <!-- GPS -->
      <sensor name="navsat_sensor" type="navsat">
        <always_on>1</always_on>
        <update_rate>10</update_rate>
      </sensor>
    </link>

    <link name="left_aileron">
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.8434</ixx><ixy>0</ixy><iyy>0.0119</iyy><ixz>0</ixz><iyz>0</iyz><izz>0.855</izz></inertia>
        <pose>-1.65 3.7 1.5 0.05 0 -0.12</pose>
      </inertial>
      <collision name="collision"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/left_aileron.dae</uri></mesh></geometry></collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/left_aileron.dae</uri></mesh></geometry></visual>
    </link>

    <link name="left_flap">
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.6747</ixx><ixy>0</ixy><iyy>0.0242</iyy><ixz>0</ixz><iyz>0</iyz><izz>0.6962</izz></inertia>
        <pose>-1.8 1.55 1.43 0.02 0 0</pose>
      </inertial>
      <collision name="collision"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/left_flap.dae</uri></mesh></geometry></collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/left_flap.dae</uri></mesh></geometry></visual>
    </link>

    <link name="right_aileron">
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.8434</ixx><ixy>0</ixy><iyy>0.0119</iyy><ixz>0</ixz><iyz>0</iyz><izz>0.855</izz></inertia>
        <pose>-1.65 -3.7 1.5 -0.05 0 0.12</pose>
      </inertial>
      <collision name="collision"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/right_aileron.dae</uri></mesh></geometry></collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/right_aileron.dae</uri></mesh></geometry></visual>
    </link>

    <link name="right_flap">
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.6747</ixx><ixy>0</ixy><iyy>0.0242</iyy><ixz>0</ixz><iyz>0</iyz><izz>0.6962</izz></inertia>
        <pose>-1.8 -1.55 1.43 -0.02 0 0</pose>
      </inertial>
      <collision name="collision"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/right_flap.dae</uri></mesh></geometry></collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/right_flap.dae</uri></mesh></geometry></visual>
    </link>

    <link name="elevators">
      <inertial>
        <mass>2</mass>
        <inertia><ixx>1.5008</ixx><ixy>0</ixy><iyy>0.0274</iyy><ixz>0</ixz><iyz>0</iyz><izz>1.5266</izz></inertia>
        <pose>-5.75 0 0.57 0 0 0</pose>
      </inertial>
      <collision name="collision"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/elevators.dae</uri></mesh></geometry></collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/elevators.dae</uri></mesh></geometry></visual>
    </link>

    <link name="rudder">
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.4708</ixx><ixy>0</ixy><iyy>0.5208</iyy><ixz>0</ixz><iyz>0</iyz><izz>0.0508</izz></inertia>
        <pose>-6.1 0 1.3 0 -0.35 0</pose>
      </inertial>
      <collision name="collision"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/rudder.dae</uri></mesh></geometry></collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/rudder.dae</uri></mesh></geometry></visual>
    </link>

    <link name="propeller">
      <pose>1.79 0 0.855 0 0 0</pose>
      <inertial>
        <mass>18.37</mass>
        <inertia><ixx>7.5067</ixx><ixy>0</ixy><iyy>7.5150</iyy><ixz>0</ixz><iyz>0</iyz><izz>0.068275</izz></inertia>
        <pose>-0.35 0 0 0 0 0</pose>
      </inertial>
      <collision name="collision"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/cessna_prop.dae</uri></mesh></geometry></collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/cessna_prop.dae</uri></mesh></geometry></visual>
    </link>

    <link name="front_wheel">
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.01786</ixx><ixy>0</ixy><iyy>0.01786</iyy><ixz>0</ixz><iyz>0</iyz><izz>0.0324</izz></inertia>
        <pose>0.712 0 -0.313 1.570795 0 0</pose>
      </inertial>
      <collision name="collision">
        <pose>0.712 0 -0.313 1.570795 0 0</pose>
        <geometry><cylinder><radius>0.18</radius><length>0.1</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>0.3</mu><mu2>0.3</mu2></ode></friction>
          <contact><ode><max_vel>0.1</max_vel><min_depth>0.001</min_depth></ode></contact>
        </surface>
      </collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/cessna_front_wheel.dae</uri></mesh></geometry></visual>
    </link>

    <link name="rear_left_wheel">
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.035516</ixx><ixy>0</ixy><iyy>0.035516</iyy><ixz>0</ixz><iyz>0</iyz><izz>0.0625</izz></inertia>
        <pose>-1 1.27 -0.25 1.570795 0 0</pose>
      </inertial>
      <collision name="collision">
        <pose>-1 1.27 -0.25 1.570795 0 0</pose>
        <geometry><cylinder><radius>0.25</radius><length>0.16</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>0.3</mu><mu2>0.3</mu2></ode></friction>
          <contact><ode><max_vel>0.1</max_vel><min_depth>0.001</min_depth></ode></contact>
        </surface>
      </collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/cessna_rear_left_wheel.dae</uri></mesh></geometry></visual>
    </link>

    <link name="rear_right_wheel">
      <inertial>
        <mass>2</mass>
        <inertia><ixx>0.035516</ixx><ixy>0</ixy><iyy>0.035516</iyy><ixz>0</ixz><iyz>0</iyz><izz>0.0625</izz></inertia>
        <pose>-1 -1.27 -0.25 1.570795 0 0</pose>
      </inertial>
      <collision name="collision">
        <pose>-1 -1.27 -0.25 1.570795 0 0</pose>
        <geometry><cylinder><radius>0.25</radius><length>0.16</length></cylinder></geometry>
        <surface>
          <friction><ode><mu>0.3</mu><mu2>0.3</mu2></ode></friction>
          <contact><ode><max_vel>0.1</max_vel><min_depth>0.001</min_depth></ode></contact>
        </surface>
      </collision>
      <visual name="visual"><geometry><mesh><uri>https://fuel.gazebosim.org/1.0/openrobotics/models/cessna c-172/3/files/meshes/cessna_rear_right_wheel.dae</uri></mesh></geometry></visual>
    </link>

    <!-- ===================== KAMERALAR ===================== -->
    <!-- Aşağı bakan QR kamerası — gövde altı, pitch=90° -->
    <link name="camera_down_link">
      <pose>-0.5 0 0.5 0 1.5707963 0</pose>
      <visual name="vis">
        <geometry><box><size>0.1 0.1 0.1</size></box></geometry>
        <material><ambient>0.8 0.1 0.1 1</ambient></material>
      </visual>
      <sensor name="camera_down" type="camera">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.047</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.1</near><far>300</far></clip>
        </camera>
        <topic>/plane/camera/down/image_raw</topic>
      </sensor>
    </link>
    <joint name="camera_down_joint" type="fixed">
      <parent>body</parent><child>camera_down_link</child>
    </joint>

    <!-- Öne bakan FPV kamerası — burun, 15° aşağı -->
    <link name="camera_front_link">
      <pose>1.5 0 1.0 0 0.2618 0</pose>
      <visual name="vis">
        <geometry><box><size>0.1 0.1 0.08</size></box></geometry>
        <material><ambient>0.8 0.1 0.1 1</ambient></material>
      </visual>
      <sensor name="camera_front" type="camera">
        <always_on>1</always_on>
        <update_rate>30</update_rate>
        <camera>
          <horizontal_fov>1.2217</horizontal_fov>
          <image><width>1280</width><height>720</height><format>R8G8B8</format></image>
          <clip><near>0.1</near><far>500</far></clip>
        </camera>
        <topic>/plane/camera/front/image_raw</topic>
      </sensor>
    </link>
    <joint name="camera_front_joint" type="fixed">
      <parent>body</parent><child>camera_front_link</child>
    </joint>

    <!-- ===================== JOINTLER ===================== -->
    <joint name="left_flap_joint" type="revolute">
      <parent>body</parent><child>left_flap</child>
      <pose>-1.6 1.55 1.43 0.02 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-0.53</lower><upper>0.53</upper></limit><dynamics><damping>1.0</damping></dynamics></axis>
    </joint>
    <joint name="left_aileron_joint" type="revolute">
      <parent>body</parent><child>left_aileron</child>
      <pose>-1.45 3.7 1.5 0.05 0 -0.12</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-0.53</lower><upper>0.53</upper></limit><dynamics><damping>1.0</damping></dynamics></axis>
    </joint>
    <joint name="right_flap_joint" type="revolute">
      <parent>body</parent><child>right_flap</child>
      <pose>-1.6 -1.55 1.43 -0.02 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-0.53</lower><upper>0.53</upper></limit><dynamics><damping>1.0</damping></dynamics></axis>
    </joint>
    <joint name="right_aileron_joint" type="revolute">
      <parent>body</parent><child>right_aileron</child>
      <pose>-1.45 -3.7 1.5 -0.05 0 0.12</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-0.53</lower><upper>0.53</upper></limit><dynamics><damping>1.0</damping></dynamics></axis>
    </joint>
    <joint name="elevators_joint" type="revolute">
      <parent>body</parent><child>elevators</child>
      <pose>-5.55 0 0.57 0 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-0.53</lower><upper>0.53</upper></limit><dynamics><damping>1.0</damping></dynamics></axis>
    </joint>
    <joint name="rudder_joint" type="revolute">
      <parent>body</parent><child>rudder</child>
      <pose>-5.9 0 1.3 0 -0.35 0</pose>
      <axis><xyz>0 0 1</xyz><limit><lower>-0.53</lower><upper>0.53</upper></limit><dynamics><damping>1.0</damping></dynamics></axis>
    </joint>
    <joint name="propeller_joint" type="revolute">
      <parent>body</parent><child>propeller</child>
      <axis><xyz>1 0 0</xyz><limit><lower>-1e12</lower><upper>1e12</upper></limit><dynamics><damping>0.001</damping></dynamics></axis>
    </joint>
    <joint name="front_wheel_joint" type="revolute">
      <parent>body</parent><child>front_wheel</child>
      <pose>0.712 0 -0.313 0 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e12</lower><upper>1e12</upper></limit><dynamics><damping>0.01</damping></dynamics></axis>
    </joint>
    <joint name="rear_left_wheel_joint" type="revolute">
      <parent>body</parent><child>rear_left_wheel</child>
      <pose>-1 -1.27 -0.25 0 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e12</lower><upper>1e12</upper></limit><dynamics><damping>0.01</damping></dynamics></axis>
    </joint>
    <joint name="rear_right_wheel_joint" type="revolute">
      <parent>body</parent><child>rear_right_wheel</child>
      <pose>-1 1.27 -0.25 0 0 0</pose>
      <axis><xyz>0 1 0</xyz><limit><lower>-1e12</lower><upper>1e12</upper></limit><dynamics><damping>0.01</damping></dynamics></axis>
    </joint>

    <!-- ===================== PLUGİNLER ===================== -->
    <plugin filename="gz-sim-joint-state-publisher-system"
      name="gz::sim::systems::JointStatePublisher"></plugin>

    <!-- Ana kanat lift/drag -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <a0>0.13</a0><cla>4.0</cla><cda>0.06</cda><cma>0.0</cma>
      <alpha_stall>0.35</alpha_stall><cla_stall>-3.85</cla_stall><cda_stall>-0.92</cda_stall><cma_stall>0.0</cma_stall>
      <cp>-0.5 0 1.5</cp><area>8.0</area><air_density>1.2041</air_density>
      <forward>1 0 0</forward><upward>0 0 1</upward><link_name>body</link_name>
    </plugin>

    <!-- Sol aileron lift/drag -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <a0>0.13</a0><cla>4.0</cla><cda>0.06</cda><cma>0.0</cma>
      <alpha_stall>0.35</alpha_stall><cla_stall>-3.85</cla_stall><cda_stall>-0.92</cda_stall><cma_stall>0.0</cma_stall>
      <cp>-1.5 3.7 1.5</cp><area>1.0</area><air_density>1.2041</air_density>
      <forward>1 0 0</forward><upward>0 0 1</upward><link_name>body</link_name>
      <control_joint_name>left_aileron_joint</control_joint_name>
      <control_joint_rad_to_cl>-4.0</control_joint_rad_to_cl>
    </plugin>

    <!-- Sağ aileron lift/drag -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <a0>0.13</a0><cla>4.0</cla><cda>0.06</cda><cma>0.0</cma>
      <alpha_stall>0.35</alpha_stall><cla_stall>-3.85</cla_stall><cda_stall>-0.92</cda_stall><cma_stall>0.0</cma_stall>
      <cp>-1.5 -3.7 1.5</cp><area>1.0</area><air_density>1.2041</air_density>
      <forward>1 0 0</forward><upward>0 0 1</upward><link_name>body</link_name>
      <control_joint_name>right_aileron_joint</control_joint_name>
      <control_joint_rad_to_cl>4.0</control_joint_rad_to_cl>
    </plugin>

    <!-- Elevator lift/drag -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <a0>0.0</a0><cla>4.5</cla><cda>0.06</cda><cma>0.0</cma>
      <alpha_stall>0.35</alpha_stall><cla_stall>-3.85</cla_stall><cda_stall>-0.92</cda_stall><cma_stall>0.0</cma_stall>
      <cp>-5.75 0 0.57</cp><area>1.2</area><air_density>1.2041</air_density>
      <forward>1 0 0</forward><upward>0 0 1</upward><link_name>body</link_name>
      <control_joint_name>elevators_joint</control_joint_name>
      <control_joint_rad_to_cl>-5.0</control_joint_rad_to_cl>
    </plugin>

    <!-- Rudder lift/drag -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <a0>0.0</a0><cla>3.5</cla><cda>0.06</cda><cma>0.0</cma>
      <alpha_stall>0.35</alpha_stall><cla_stall>-3.85</cla_stall><cda_stall>-0.92</cda_stall><cma_stall>0.0</cma_stall>
      <cp>-6.0 0 1.5</cp><area>0.8</area><air_density>1.2041</air_density>
      <forward>1 0 0</forward><upward>0 1 0</upward><link_name>body</link_name>
      <control_joint_name>rudder_joint</control_joint_name>
      <control_joint_rad_to_cl>4.0</control_joint_rad_to_cl>
    </plugin>

    <!-- Pervane bıçak 1 -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <a0>0.30</a0><alpha_stall>1.4</alpha_stall><cla>4.25</cla><cda>0.10</cda>
      <cma>0.0</cma><cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
      <area>0.1</area><air_density>1.2041</air_density>
      <cp>0 0 0.5</cp><forward>0 -1 0</forward><upward>1 0 0</upward>
      <link_name>propeller</link_name>
    </plugin>

    <!-- Pervane bıçak 2 -->
    <plugin filename="gz-sim-lift-drag-system" name="gz::sim::systems::LiftDrag">
      <a0>0.30</a0><alpha_stall>1.4</alpha_stall><cla>4.25</cla><cda>0.10</cda>
      <cma>0.0</cma><cla_stall>-0.025</cla_stall><cda_stall>0.0</cda_stall><cma_stall>0.0</cma_stall>
      <area>0.1</area><air_density>1.2041</air_density>
      <cp>0 0 -0.5</cp><forward>0 1 0</forward><upward>1 0 0</upward>
      <link_name>propeller</link_name>
    </plugin>

    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>propeller_joint</joint_name></plugin>
    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>left_aileron_joint</joint_name></plugin>
    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>right_aileron_joint</joint_name></plugin>
    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>elevators_joint</joint_name></plugin>
    <plugin filename="gz-sim-apply-joint-force-system" name="gz::sim::systems::ApplyJointForce">
      <joint_name>rudder_joint</joint_name></plugin>

    <!-- ===================== ARDUPİLOT ===================== -->
    <plugin name="ArduPilotPlugin" filename="libArduPilotPlugin.so">
      <fdm_addr>127.0.0.1</fdm_addr>
      <fdm_port_in>9012</fdm_port_in>
      <connectionTimeoutMaxCount>5</connectionTimeoutMaxCount>
      <lock_step>0</lock_step>
      <no_time_sync>1</no_time_sync>
      <!-- Cessna: x=forward, y=left, z=up → NED: 180° roll -->
      <modelXYZToAirplaneXForwardZDown degrees="true">0 0 0 180 0 0</modelXYZToAirplaneXForwardZDown>
      <gazeboXYZToNED degrees="true">0 0 0 180 0 90</gazeboXYZToNED>
      <imuName>body::imu_sensor</imuName>

      <!-- ch0: Sol aileron -->
      <control channel="0">
        <jointName>left_aileron_joint</jointName>
        <useForce>1</useForce><multiplier>1.048</multiplier><offset>-0.5</offset>
        <servo_min>1100</servo_min><servo_max>1900</servo_max>
        <type>POSITION</type><p_gain>10.0</p_gain>
        <i_gain>0</i_gain><d_gain>0</d_gain><i_max>0</i_max><i_min>0</i_min>
        <cmd_max>2.5</cmd_max><cmd_min>-2.5</cmd_min>
      </control>

      <!-- ch1: Sağ aileron (ters) -->
      <control channel="1">
        <jointName>right_aileron_joint</jointName>
        <useForce>1</useForce><multiplier>-1.048</multiplier><offset>-0.5</offset>
        <servo_min>1100</servo_min><servo_max>1900</servo_max>
        <type>POSITION</type><p_gain>10.0</p_gain>
        <i_gain>0</i_gain><d_gain>0</d_gain><i_max>0</i_max><i_min>0</i_min>
        <cmd_max>2.5</cmd_max><cmd_min>-2.5</cmd_min>
      </control>

      <!-- ch2: Gaz -->
      <control channel="2">
        <jointName>propeller_joint</jointName>
        <useForce>1</useForce><multiplier>838</multiplier><offset>0</offset>
        <servo_min>1100</servo_min><servo_max>1900</servo_max>

<plugin name="ArduPilotPlugin" filename="libArduPilotPlugin.so">

<fdm_addr>127.0.0.1</fdm_addr>

<fdm_port_in>9002</fdm_port_in>

<connectionTimeoutMaxCount>50</connectionTimeoutMaxCount>

<lock_step>0</lock_step>

<no_time_sync>1</no_time_sync>

<modelXYZToAirplaneXForwardZDown degrees="true">0 0 0 180 0 -90</modelXYZToAirplaneXForwardZDown>

<gazeboXYZToNED degrees="true">0 0 0 180 0 90</gazeboXYZToNED>

<imuName>base_link::imu_sensor</imuName>

<control channel="0">

<jointName>servo_0</jointName>

<useForce>1</useForce><multiplier>1.048</multiplier><offset>-0.5</offset>

<servo_min>1100</servo_min><servo_max>1900</servo_max>

<type>POSITION</type><p_gain>10.0</p_gain>

<i_gain>0</i_gain><d_gain>0</d_gain><i_max>0</i_max><i_min>0</i_min>

<cmd_max>2.5</cmd_max><cmd_min>-2.5</cmd_min>

</control>

<control channel="1">

<jointName>servo_1</jointName>

<useForce>1</useForce><multiplier>1.048</multiplier><offset>-0.5</offset>

<servo_min>1100</servo_min><servo_max>1900</servo_max>

<type>POSITION</type><p_gain>10.0</p_gain>

<i_gain>0</i_gain><d_gain>0</d_gain><i_max>0</i_max><i_min>0</i_min>

<cmd_max>2.5</cmd_max><cmd_min>-2.5</cmd_min>

</control>

